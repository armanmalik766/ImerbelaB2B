
{% comment %}
  IMERBELA - Shop by Hair Concerns Section
  Minimalist concern-based navigation
{% endcomment %}

<style>
  .imerbela-concerns {
    background-color: #ffffff;
    padding: 100px 0;
    font-family: 'Inter', sans-serif;
    color: #111111;
  }

  .imerbela-concerns__header {
    max-width: 1200px;
    margin: 0 auto 60px;
    padding: 0 24px;
  }

  .imerbela-concerns__title {
    font-size: 32px;
    font-weight: 300;
    letter-spacing: -0.02em;
    margin: 0 0 16px 0;
  }

  .imerbela-concerns__line {
    width: 48px;
    height: 1px;
    background-color: #6B8E23;
  }

  .imerbela-concerns__grid {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 24px;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 32px;
  }

  @media (max-width: 991px) {
    .imerbela-concerns {
      padding: 60px 0;
    }
    .imerbela-concerns__grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 24px;
    }
  }

  @media (max-width: 767px) {
    .imerbela-concerns__grid {
      display: flex;
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      padding-bottom: 30px;
      margin-left: -24px;
      padding-left: 24px;
      gap: 20px;
      -ms-overflow-style: none;
      scrollbar-width: none;
    }
    .imerbela-concerns__grid::-webkit-scrollbar {
      display: none;
    }
    .imerbela-concerns__card {
      min-width: 260px;
      scroll-snap-align: center;
    }
  }

  .imerbela-concerns__card {
    text-decoration: none;
    color: inherit;
    display: block;
    cursor: pointer;
  }

  .imerbela-concerns__img-wrapper {
    aspect-ratio: 4 / 5;
    background-color: #f8f8f8;
    overflow: hidden;
    margin-bottom: 20px;
  }

  .imerbela-concerns__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: grayscale(15%);
    transition: transform 0.8s cubic-bezier(0.165, 0.84, 0.44, 1);
  }

  .imerbela-concerns__card:hover .imerbela-concerns__img {
    transform: scale(1.06);
  }

  .imerbela-concerns__label {
    display: block;
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    margin-bottom: 4px;
    transition: color 0.3s ease;
  }

  .imerbela-concerns__card:hover .imerbela-concerns__label {
    color: #6B8E23;
  }

  .imerbela-concerns__cta {
    display: block;
    font-size: 10px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #aaaaaa;
    opacity: 0;
    transform: translateY(4px);
    transition: all 0.3s ease;
  }

  .imerbela-concerns__card:hover .imerbela-concerns__cta {
    opacity: 1;
    transform: translateY(0);
  }
</style>

<div class="imerbela-concerns">
  <div class="imerbela-concerns__header">
    <h2 class="imerbela-concerns__title">{{ section.settings.title }}</h2>
    <div class="imerbela-concerns__line"></div>
  </div>

  <div class="imerbela-concerns__grid">
    {% for block in section.blocks %}
      <a href="{{ block.settings.link }}" class="imerbela-concerns__card" {{ block.shopify_attributes }}>
        <div class="imerbela-concerns__img-wrapper">
          {% if block.settings.image %}
            <img 
              src="{{ block.settings.image | image_url: width: 800 }}" 
              alt="{{ block.settings.label }}" 
              class="imerbela-concerns__img"
              loading="lazy"
            >
          {% else %}
            {{ 'image' | placeholder_svg_tag: 'imerbela-concerns__img' }}
          {% endif %}
        </div>
        <span class="imerbela-concerns__label">{{ block.settings.label }}</span>
        <span class="imerbela-concerns__cta">Identify Solution →</span>
      </a>
    {% endfor %}
  </div>
</div>

{% schema %}
{
  "name": "Shop by Hair Concerns",
  "max_blocks": 4,
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Section Title",
      "default": "Shop by Hair Concerns"
    }
  ],
  "blocks": [
    {
      "type": "concern",
      "name": "Concern Card",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Concern Image"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Dandruff / Flaky Scalp"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link to Collection/Product"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Shop by Hair Concerns",
      "blocks": [
        { "type": "concern", "settings": { "label": "Dandruff / Flaky Scalp" } },
        { "type": "concern", "settings": { "label": "Hair Fall & Weak Roots" } },
        { "type": "concern", "settings": { "label": "Dry & Itchy Scalp" } },
        { "type": "concern", "settings": { "label": "Oily Scalp & Build-up" } }
      ]
    }
  ]
}
{% endschema %}
